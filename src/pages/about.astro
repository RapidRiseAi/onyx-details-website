---
import MainLayout from '../layouts/MainLayout.astro';
import PageHero from '../components/PageHero.astro';
import ServiceAreas from '../components/ServiceAreas.astro';
import CTASection from '../components/CTASection.astro';
import { pageSeo } from '../data/seo';
---
<MainLayout title={pageSeo.about.title} description={pageSeo.about.description}>
  <PageHero title="A Premium Mobile Service Built Around Convenience" subtitle="Convenience without compromise for drivers, farms, and work fleets." />
  <section class="section"><div class="container split"><div><h2>Business Promise</h2><p>OnyxDetails is designed for customers who value presentation and time. You get premium care at your location, without spending your day in a queue.</p><p>From one-off details to recurring plans, every visit is built around consistency, professionalism, and a refined finish.</p></div><img src="/assets/images/about/Premium-Service-Promise.png" alt="Premium detailing lifestyle visual" /></div></section>
  <section class="section"><div class="container"><h2>What Makes OnyxDetails Different</h2><div class="feature-grid">{['Mobile convenience','Premium recurring upkeep','Professional presentation','Service for home, farm, and work environments'].map((item)=><article class="card"><h3>{item}</h3></article>)}</div></div></section>
  <ServiceAreas />
  <CTASection title="Keep your vehicle consistently presentable" text="Book a premium mobile service that fits your routine." />
</MainLayout>
