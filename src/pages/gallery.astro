---
import MainLayout from '../layouts/MainLayout.astro';
import PageHero from '../components/PageHero.astro';
import ImageCarousel from '../components/ImageCarousel.astro';
import CTASection from '../components/CTASection.astro';
import Lightbox from '../components/Lightbox.astro';
import { galleryItems } from '../data/gallery';
import { pageSeo } from '../data/seo';

const beforeAfterItems = galleryItems.filter((item) => item.category === 'before-after');
const finishedCarsItems = galleryItems.filter((item) => item.category === 'finished-cars');
const lifestyleItems = galleryItems.filter((item) => item.category === 'lifestyle');
const teamItems = galleryItems.filter((item) => item.category === 'team');
---
<MainLayout title={pageSeo.gallery.title} description={pageSeo.gallery.description}>
  <PageHero title="See the Difference in the Finish" subtitle="Real before and after results from premium mobile wash and detailing work." />
  <section class="section">
    <div class="container">
      <ImageCarousel items={beforeAfterItems} title="Before &amp; After" subtitle="Combined before-and-after images showing the full transformation." interactive={true} />
      <ImageCarousel items={finishedCarsItems} title="Finished Cars" subtitle="Freshly detailed vehicles ready for handover." interactive={true} />
      <ImageCarousel items={lifestyleItems} title="Lifestyle" subtitle="Mobile detailing in real home and farm environments." interactive={true} />
      <ImageCarousel items={teamItems} title="Team" subtitle="Behind the scenes of our process and quality checks." interactive={true} />
      <Lightbox />
    </div>
  </section>
  <CTASection title="Ready for your own transformation?" text="Book your premium mobile wash or detailing package today." />
</MainLayout>
