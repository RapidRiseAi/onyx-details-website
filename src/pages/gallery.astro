---
import MainLayout from '../layouts/MainLayout.astro';
import PageHero from '../components/PageHero.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import BeforeAfterCarousel from '../components/BeforeAfterCarousel.astro';
import CTASection from '../components/CTASection.astro';
import Lightbox from '../components/Lightbox.astro';
import { galleryItems } from '../data/gallery';
import { pageSeo } from '../data/seo';

const beforeAfterItems = galleryItems.filter((item) => item.category === 'before-after');
const showcaseItems = galleryItems.filter((item) => item.category !== 'before-after');
---
<MainLayout title={pageSeo.gallery.title} description={pageSeo.gallery.description}>
  <PageHero title="See the Difference in the Finish" subtitle="Real before and after results from premium mobile wash and detailing work." />
  <section class="section">
    <div class="container">
      <BeforeAfterCarousel items={beforeAfterItems} />
      <div class="filters">
        <button class="btn btn-subtle active" data-filter="all">All Showcase Images</button>
        <button class="btn btn-subtle" data-filter="finished-cars">Finished Cars</button>
        <button class="btn btn-subtle" data-filter="lifestyle">Lifestyle</button>
        <button class="btn btn-subtle" data-filter="team">Team</button>
      </div>
      <GalleryGrid items={showcaseItems} interactive={true} />
      <Lightbox />
    </div>
  </section>
  <CTASection title="Ready for your own transformation?" text="Book your premium mobile wash or detailing package today." />
</MainLayout>
