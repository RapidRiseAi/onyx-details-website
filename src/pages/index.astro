---
import MainLayout from '../layouts/MainLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import PromoBanner from '../components/PromoBanner.astro';
import HowItWorks from '../components/HowItWorks.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ServiceAreas from '../components/ServiceAreas.astro';
import CTASection from '../components/CTASection.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import ImageCarousel from '../components/ImageCarousel.astro';
import { services } from '../data/services';
import { testimonials } from '../data/testimonials';
import { galleryItems } from '../data/gallery';
import { pageSeo } from '../data/seo';

const beforeAfterItems = galleryItems.filter((item) => item.category === 'before-after');
---
<MainLayout title={pageSeo.home.title} description={pageSeo.home.description}>
  <HeroSection />
  <section class="section"><div class="container"><h2>Why Choose OnyxDetails</h2><div class="feature-grid">{['We come to you','Premium finish','Recurring plans available','Professional and reliable','Suitable for homes, farms, and workplaces'].map((p)=><article class="card"><h3>{p}</h3></article>)}</div></div></section>
  <section class="section"><div class="container"><h2>Services Preview</h2><ServiceGrid services={services.filter((s)=>['basic-wash','detail-interior-exterior','detail-bi-weekly','special-pack'].includes(s.id))} /></div></section>
  <PromoBanner />
  <HowItWorks />
  <section class="section"><div class="container"><ImageCarousel items={beforeAfterItems} title="Before and After Results" subtitle="A quick look at real transformations from recent details." /><p><a class="btn btn-ghost" href="/gallery">View Full Gallery</a></p></div></section>
  <section class="section"><div class="container split"><img src="/Built-Around-Convenience.png" alt="Premium mobile detailing service" loading="lazy" /><div><h2>Built Around Convenience, Quality, and Consistency</h2><p>OnyxDetails exists to make it easier for customers to keep their vehicles clean without sacrificing time or convenience. The business is built around premium mobile service, consistent presentation, and dependable care for vehicles at homes, farms, and work locations.</p></div></div></section>
  <section class="section"><div class="container"><h2>Client Feedback</h2><TestimonialCard testimonial={testimonials[0]} /></div></section>
  <ServiceAreas />
  <CTASection title="Ready to Book a Premium Mobile Wash?" text="Choose your package and send your enquiry in minutes." />
</MainLayout>
