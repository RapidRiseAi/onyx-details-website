---
import type { Service } from '../data/services';
import ServiceCard from './ServiceCard.astro';

interface Props {
  services: Service[];
  carouselOnMobile?: boolean;
}

const { services, carouselOnMobile = false } = Astro.props;
---
{
  carouselOnMobile ? (
    <section class="service-carousel" data-service-carousel>
      <div class="service-mobile-controls">
        <button type="button" class="carousel-control" data-service-carousel-prev aria-label="Show previous service">‹</button>
        <button type="button" class="carousel-control" data-service-carousel-next aria-label="Show next service">›</button>
      </div>
      <div class="service-grid service-grid-carousel" data-service-carousel-track>
        {services.map((service) => <ServiceCard service={service} />)}
      </div>
    </section>
  ) : (
    <div class="service-grid">{services.map((service) => <ServiceCard service={service} />)}</div>
  )
}
