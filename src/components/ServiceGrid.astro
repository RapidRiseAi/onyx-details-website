---
import type { Service } from '../data/services';
import ServiceCard from './ServiceCard.astro';
interface Props {
  services: Service[];
  carouselOnMobile?: boolean;
}
const { services, carouselOnMobile = false } = Astro.props;
---
{
  carouselOnMobile ? (
    <>
      <div class="service-grid service-grid-desktop">{services.map((service) => <ServiceCard service={service} />)}</div>
      <section class="service-carousel" data-service-carousel>
        <button class="service-carousel-control" data-service-carousel-prev aria-label="Show previous service">‹</button>
        <div class="service-grid-mobile-carousel" data-service-carousel-track>
          {services.map((service) => <ServiceCard service={service} />)}
        </div>
        <button class="service-carousel-control" data-service-carousel-next aria-label="Show next service">›</button>
        <div class="service-carousel-dots" data-service-carousel-dots aria-label="Service carousel navigation"></div>
      </section>
    </>
  ) : (
    <div class="service-grid">{services.map((service) => <ServiceCard service={service} />)}</div>
  )
}
