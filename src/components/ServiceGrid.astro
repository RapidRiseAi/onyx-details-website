---
import type { Service } from '../data/services';
import ServiceCard from './ServiceCard.astro';

interface Props {
  services: Service[];
  carouselOnMobile?: boolean;
}

const { services, carouselOnMobile = false } = Astro.props;
---
{
  carouselOnMobile ? (
    <>
      <div class="service-grid service-grid-desktop" data-service-desktop-grid>
        {services.map((service) => <ServiceCard service={service} />)}
      </div>
      <section class="service-grid-mobile-shell" aria-label="Swipe through services" data-service-mobile-shell>
        <div class="service-grid-mobile-track" data-service-mobile-track>
          {services.map((service) => <ServiceCard service={service} />)}
        </div>
      </section>
    </>
  ) : (
    <div class="service-grid">{services.map((service) => <ServiceCard service={service} />)}</div>
  )
}
