---
import type { Service } from '../data/services';
import ServiceCard from './ServiceCard.astro';
interface Props {
  services: Service[];
  carouselOnMobile?: boolean;
}
const { services, carouselOnMobile = false } = Astro.props;
---
{
  carouselOnMobile ? (
    <>
      <div class="service-grid service-grid-desktop">{services.map((service) => <ServiceCard service={service} />)}</div>
      <section class="service-carousel" data-scroll-sync aria-label="Swipe through services">
        <div class="service-grid-mobile-carousel" data-scroll-track>
          {services.map((service) => <ServiceCard service={service} />)}
        </div>
        <input
          class="carousel-progress"
          data-carousel-progress
          type="range"
          min="0"
          max="100"
          value="0"
          step="1"
          aria-label="Scroll through service cards"
        />
      </section>
    </>
  ) : (
    <div class="service-grid">{services.map((service) => <ServiceCard service={service} />)}</div>
  )
}
