---
import type { GalleryItem } from '../data/gallery';

interface Props {
  items: GalleryItem[];
  title: string;
  subtitle?: string;
}

const { items, title, subtitle } = Astro.props;
---
<section class="before-after-carousel-section">
  <div class="section-heading compact">
    <h2>{title}</h2>
    {subtitle && <p>{subtitle}</p>}
  </div>
  <div class="before-after-carousel" data-carousel>
    <button class="carousel-control" data-carousel-prev aria-label={`Show previous image in ${title}`}>‹</button>
    <div class="carousel-track" data-carousel-track>
      {items.map((item) => (
        <article class="carousel-slide static">
          <img src={item.src} alt={item.alt} loading="lazy" />
          <span>{item.title}</span>
        </article>
      ))}
    </div>
    <button class="carousel-control" data-carousel-next aria-label={`Show next image in ${title}`}>›</button>
  </div>
</section>

<script is:inline>
  if (!window.__onyxCarouselInit) {
    window.__onyxCarouselInit = true;

    const initCarousels = () => {
      document.querySelectorAll('[data-carousel]').forEach((carousel) => {
        const carouselTrack = carousel.querySelector('[data-carousel-track]');
        const prevButton = carousel.querySelector('[data-carousel-prev]');
        const nextButton = carousel.querySelector('[data-carousel-next]');
        if (!carouselTrack || !prevButton || !nextButton) return;

        const slides = Array.from(carouselTrack.querySelectorAll('.carousel-slide'));
        if (slides.length <= 1) return;

        let currentIndex = 0;

        const visibleSlides = () => {
          if (window.matchMedia('(max-width: 800px)').matches) return 1;
          if (window.matchMedia('(max-width: 1200px)').matches) return 2;
          return 3;
        };

        const slideSize = () => {
          const gap = parseFloat(window.getComputedStyle(carouselTrack).columnGap || '0');
          return slides[0].offsetWidth + gap;
        };

        const syncIndexFromScroll = () => {
          const unit = slideSize();
          if (unit <= 0) return;
          currentIndex = Math.round(carouselTrack.scrollLeft / unit);
        };

        const updateControls = () => {
          const mobile = window.matchMedia('(max-width: 800px)').matches;
          prevButton.disabled = mobile || currentIndex <= 0;
          nextButton.disabled = mobile || currentIndex >= Math.max(0, slides.length - visibleSlides());
        };

        const updateCarousel = (behavior = 'smooth') => {
          const maxIndex = Math.max(0, slides.length - visibleSlides());
          if (currentIndex > maxIndex) currentIndex = maxIndex;
          if (currentIndex < 0) currentIndex = 0;
          const targetLeft = currentIndex * slideSize();
          carouselTrack.scrollTo({ left: targetLeft, behavior });
          updateControls();
        };

        prevButton.addEventListener('click', () => {
          currentIndex -= 1;
          updateCarousel();
        });

        nextButton.addEventListener('click', () => {
          currentIndex += 1;
          updateCarousel();
        });

        let pointerActive = false;
        let pointerId = null;
        let startX = 0;
        let startScrollLeft = 0;
        const dragThreshold = 8;
        let didDrag = false;

        carouselTrack.addEventListener('pointerdown', (event) => {
          if (event.pointerType === 'mouse' && event.button !== 0) return;
          pointerActive = true;
          pointerId = event.pointerId;
          didDrag = false;
          startX = event.clientX;
          startScrollLeft = carouselTrack.scrollLeft;
          carouselTrack.classList.add('dragging');
          carouselTrack.setPointerCapture(event.pointerId);
        });

        carouselTrack.addEventListener(
          'pointermove',
          (event) => {
            if (!pointerActive || pointerId !== event.pointerId) return;
            const distance = event.clientX - startX;
            if (!didDrag && Math.abs(distance) >= dragThreshold) didDrag = true;
            if (!didDrag) return;
            event.preventDefault();
            carouselTrack.scrollLeft = startScrollLeft - distance;
          },
          { passive: false }
        );

        const endPointerDrag = (event) => {
          if (!pointerActive || pointerId !== event.pointerId) return;
          pointerActive = false;
          pointerId = null;
          carouselTrack.classList.remove('dragging');
          syncIndexFromScroll();
          updateControls();
        };

        carouselTrack.addEventListener('pointerup', endPointerDrag);
        carouselTrack.addEventListener('pointercancel', endPointerDrag);
        carouselTrack.addEventListener('lostpointercapture', () => {
          pointerActive = false;
          pointerId = null;
          carouselTrack.classList.remove('dragging');
        });

        carouselTrack.addEventListener('scroll', () => {
          syncIndexFromScroll();
          updateControls();
        }, { passive: true });

        window.addEventListener('resize', () => updateCarousel('auto'));
        updateCarousel('auto');
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCarousels, { once: true });
    } else {
      initCarousels();
    }
  }
</script>
