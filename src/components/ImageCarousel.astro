---
import type { GalleryItem } from '../data/gallery';

interface Props {
  items: GalleryItem[];
  title: string;
  subtitle?: string;
  interactive?: boolean;
}

const { items, title, subtitle, interactive = false } = Astro.props;
---
<section class="before-after-carousel-section">
  <div class="section-heading compact">
    <h2>{title}</h2>
    {subtitle && <p>{subtitle}</p>}
  </div>
  <div class="before-after-carousel" data-carousel>
    <button class="carousel-control" data-carousel-prev aria-label={`Show previous image in ${title}`}>‹</button>
    <div class="carousel-track" data-carousel-track>
      {interactive ? items.map((item) => (
        <button class="carousel-slide" data-lightbox-src={item.src} data-lightbox-alt={item.alt}>
          <img src={item.src} alt={item.alt} loading="lazy" />
          <span>{item.title}</span>
        </button>
      )) : items.map((item) => (
        <article class="carousel-slide static">
          <img src={item.src} alt={item.alt} loading="lazy" />
          <span>{item.title}</span>
        </article>
      ))}
    </div>
    <button class="carousel-control" data-carousel-next aria-label={`Show next image in ${title}`}>›</button>
  </div>
</section>

<script is:inline>
  if (!window.__onyxCarouselInit) {
    window.__onyxCarouselInit = true;

    const initCarousels = () => {
      document.querySelectorAll('[data-carousel]').forEach((carousel) => {
        const carouselTrack = carousel.querySelector('[data-carousel-track]');
        const prevButton = carousel.querySelector('[data-carousel-prev]');
        const nextButton = carousel.querySelector('[data-carousel-next]');
        if (!carouselTrack || !prevButton || !nextButton) return;

        const slides = Array.from(carouselTrack.querySelectorAll('.carousel-slide'));
        if (slides.length <= 1) return;

        let currentIndex = 0;
        let isDragging = false;
        let dragStartX = 0;
        let dragStartLeft = 0;
        let draggedDistance = 0;
        let blockClickUntil = 0;

        const visibleSlides = () => {
          if (window.matchMedia('(max-width: 800px)').matches) return 1;
          if (window.matchMedia('(max-width: 1200px)').matches) return 2;
          return 3;
        };

        const slideSize = () => {
          const gap = parseFloat(window.getComputedStyle(carouselTrack).columnGap || '0');
          return slides[0].offsetWidth + gap;
        };

        const syncIndexFromScroll = () => {
          const unit = slideSize();
          if (unit <= 0) return;
          currentIndex = Math.round(carouselTrack.scrollLeft / unit);
        };

        const updateCarousel = (behavior = 'smooth') => {
          const maxIndex = Math.max(0, slides.length - visibleSlides());
          if (currentIndex > maxIndex) currentIndex = 0;
          if (currentIndex < 0) currentIndex = maxIndex;
          const targetLeft = currentIndex * slideSize();
          carouselTrack.scrollTo({ left: targetLeft, behavior });
        };

        const startDrag = (clientX) => {
          isDragging = true;
          dragStartX = clientX;
          dragStartLeft = carouselTrack.scrollLeft;
          draggedDistance = 0;
          carouselTrack.classList.add('dragging');
        };

        const moveDrag = (clientX) => {
          if (!isDragging) return;
          const distance = clientX - dragStartX;
          draggedDistance = Math.max(draggedDistance, Math.abs(distance));
          carouselTrack.scrollLeft = dragStartLeft - distance;
        };

        const endDrag = () => {
          if (!isDragging) return;
          isDragging = false;
          carouselTrack.classList.remove('dragging');
          if (draggedDistance > 8) blockClickUntil = Date.now() + 220;
          syncIndexFromScroll();
          updateCarousel();
        };

        prevButton.addEventListener('click', () => {
          currentIndex -= 1;
          updateCarousel();
        });

        nextButton.addEventListener('click', () => {
          currentIndex += 1;
          updateCarousel();
        });

        carouselTrack.addEventListener('scroll', syncIndexFromScroll, { passive: true });

        carouselTrack.addEventListener('mousedown', (event) => {
          if (event.button !== 0) return;
          startDrag(event.clientX);
        });

        carouselTrack.addEventListener('mousemove', (event) => {
          if (!isDragging) return;
          event.preventDefault();
          moveDrag(event.clientX);
        });

        carouselTrack.addEventListener('touchstart', (event) => {
          const [touch] = event.touches;
          if (!touch) return;
          startDrag(touch.clientX);
        }, { passive: true });

        carouselTrack.addEventListener('touchmove', (event) => {
          const [touch] = event.touches;
          if (!touch) return;
          moveDrag(touch.clientX);
        }, { passive: true });

        carouselTrack.addEventListener('mouseleave', endDrag);
        carouselTrack.addEventListener('mouseup', endDrag);
        carouselTrack.addEventListener('touchend', endDrag);
        carouselTrack.addEventListener('touchcancel', endDrag);
        document.addEventListener('mouseup', endDrag);
        carouselTrack.addEventListener('click', (event) => {
          if (Date.now() <= blockClickUntil) event.preventDefault();
        }, true);

        window.addEventListener('resize', () => updateCarousel('auto'));
        updateCarousel('auto');
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCarousels, { once: true });
    } else {
      initCarousels();
    }
  }
</script>
