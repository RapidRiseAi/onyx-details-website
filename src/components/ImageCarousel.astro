---
import type { GalleryItem } from '../data/gallery';

interface Props {
  items: GalleryItem[];
  title: string;
  subtitle?: string;
}

const { items, title, subtitle } = Astro.props;
---
<section class="before-after-carousel-section" data-carousel-root>
  <div class="section-heading compact">
    <h2>{title}</h2>
    {subtitle && <p>{subtitle}</p>}
  </div>

  <div class="before-after-carousel before-after-carousel-desktop" data-carousel-desktop-variant>
    <div class="before-after-carousel-controls">
      <button class="carousel-control" type="button" data-image-carousel-prev aria-label={`Show previous image in ${title}`}>‹</button>
      <button class="carousel-control" type="button" data-image-carousel-next aria-label={`Show next image in ${title}`}>›</button>
    </div>
    <div class="carousel-viewport">
      <div class="carousel-track" data-image-carousel-track>
        {items.map((item) => (
          <article class="carousel-slide static">
            <img src={item.src} alt={item.alt} loading="lazy" draggable="false" />
            <span>{item.title}</span>
          </article>
        ))}
      </div>
    </div>
  </div>

  <div class="before-after-carousel before-after-carousel-mobile" data-carousel-mobile-variant>
    <div class="before-after-carousel-controls">
      <button class="carousel-control" type="button" data-image-carousel-prev aria-label={`Show previous image in ${title}`}>‹</button>
      <button class="carousel-control" type="button" data-image-carousel-next aria-label={`Show next image in ${title}`}>›</button>
    </div>
    <div class="carousel-viewport">
      <div class="carousel-track" data-image-carousel-track>
        {items.map((item) => (
          <article class="carousel-slide static">
            <img src={item.src} alt={item.alt} loading="lazy" draggable="false" />
            <span>{item.title}</span>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
