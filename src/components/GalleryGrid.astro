---
import type { GalleryItem } from '../data/gallery';
interface Props {
  items: GalleryItem[];
  interactive?: boolean;
}
const { items, interactive = false } = Astro.props;
---
<div class="gallery-grid">
  {(interactive ? items.map((item) => (
    <button class="gallery-item" data-gallery-item data-category={item.category} data-lightbox-src={item.src} data-lightbox-alt={item.alt}>
      <img src={item.src} alt={item.alt} loading="lazy" />
      <span>{item.title}</span>
    </button>
  )) : items.map((item) => (
    <article class="gallery-item" data-gallery-item data-category={item.category}>
      <img src={item.src} alt={item.alt} loading="lazy" />
      <span>{item.title}</span>
    </article>
  ))) }
</div>
