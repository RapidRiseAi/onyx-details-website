---
import { siteConfig } from '../data/site';
---

<header class="site-header">
  <div class="container nav-wrap">
    <a href="/" class="logo-link">
      <img src={siteConfig.logoPath} alt="OnyxDetails logo" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline';" />
      <span style="display:none">OnyxDetails</span>
    </a>
    <button class="menu-toggle" aria-expanded="false" aria-controls="site-nav">Menu</button>
    <nav id="site-nav" class="site-nav">
      <a href="/">Home</a>
      <a href="/services">Services</a>
      <a href="/gallery">Gallery</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
      <button class="btn btn-primary" data-open-booking>Book Now</button>
    </nav>
  </div>
</header>
