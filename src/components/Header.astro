---
import { siteConfig } from '../data/site';
---

<header class="site-header">
  <div class="container nav-wrap">
    <a href="/" class="logo-link" aria-label="OnyxDetails Home">
      <span class="logo-square">
        <img src={siteConfig.logoPath} alt="OnyxDetails logo" loading="lazy" onerror="this.style.display='none'; this.closest('.logo-link')?.classList.add('logo-fallback');" />
      </span>
      <span class="logo-text">OnyxDetails</span>
    </a>

    <nav class="site-nav-desktop nav-group" aria-label="Primary navigation">
      <a href="/">Home</a>
      <a href="/services">Services</a>
      <a href="/gallery">Gallery</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
      <button class="btn btn-primary" data-open-booking>Book Now</button>
    </nav>

    <button class="menu-toggle" aria-expanded="false" aria-controls="site-nav">Menu</button>
    <nav id="site-nav" class="site-nav" aria-label="Mobile navigation">
      <a href="/">Home</a>
      <a href="/services">Services</a>
      <a href="/gallery">Gallery</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
      <button class="btn btn-primary" data-open-booking>Book Now</button>
    </nav>
  </div>
</header>
