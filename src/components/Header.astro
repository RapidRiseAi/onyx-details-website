---
import { siteConfig } from '../data/site';
---

<header class="site-header">
  <div class="container nav-wrap">
    <nav class="site-nav-desktop nav-group nav-group-left" aria-label="Primary left">
      <a href="/">Home</a>
      <a href="/services">Services</a>
      <a href="/gallery">Gallery</a>
    </nav>

    <a href="/" class="brand-mark" aria-label="OnyxDetails Home">
      <span class="brand-word">ONYX</span>
      <span class="brand-logo">
        <img src={siteConfig.logoPath} alt="OnyxDetails logo" loading="lazy" onerror="this.style.display='none'; this.closest('.brand-mark')?.classList.add('logo-fallback');" />
      </span>
      <span class="brand-word">DETAILS</span>
    </a>

    <nav class="site-nav-desktop nav-group nav-group-right" aria-label="Primary right">
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
      <button class="btn btn-primary" data-open-booking>Book Now</button>
    </nav>

    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-menu-panel" aria-label="Open mobile menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="mobile-menu-backdrop" data-mobile-backdrop hidden></div>
  <nav id="mobile-menu-panel" class="site-nav" aria-label="Mobile navigation" aria-hidden="true" hidden>
    <div class="site-nav-head">
      <p>Navigation</p>
      <button type="button" class="menu-close" data-mobile-menu-close aria-label="Close mobile menu">✕</button>
    </div>
    <a href="/">Home</a>
    <a href="/services">Services</a>
    <a href="/gallery">Gallery</a>
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
    <button class="btn btn-primary" data-open-booking>Book Now</button>
  </nav>
</header>
