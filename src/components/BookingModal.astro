---
import { services } from '../data/services';
---
<dialog id="booking-modal" class="booking-modal">
  <form id="booking-form" class="form card">
    <div class="modal-head"><h2>Book OnyxDetails</h2><button type="button" class="btn btn-subtle" data-close-booking>Close</button></div>
    <input type="hidden" name="serviceId" />
    <input type="hidden" name="sourcePage" />
    <label>Full Name<input name="fullName" required /></label>
    <label>Phone Number<input name="phone" required /></label>
    <label>Address<input name="address" required /></label>
    <label>Vehicle Type<input name="vehicleType" required /></label>
    <label>Selected Service
      <select name="selectedService" required>
        <option value="">Select a service</option>
        {services.map((service) => <option value={service.name}>{service.name}</option>)}
      </select>
    </label>
    <label>Preferred Date<input type="date" name="preferredDate" required /></label>
    <label>Preferred Time<input type="time" name="preferredTime" required /></label>
    <label>Special Notes<textarea name="specialNotes"></textarea></label>
    <button type="submit" class="btn btn-primary">Submit Booking Request</button>
    <p class="booking-note">Booking requests are subject to availability. OnyxDetails will contact you to confirm your booking.</p>
    <p class="form-status" aria-live="polite"></p>
  </form>
</dialog>
