---
import type { GalleryItem } from '../data/gallery';

interface Props {
  items: GalleryItem[];
}

const { items } = Astro.props;
---
<section class="before-after-carousel-section">
  <div class="section-heading compact">
    <h2>Before &amp; After Results</h2>
    <p>Swipe through transformation photos showing both before and after in a single image.</p>
  </div>
  <div class="before-after-carousel" data-carousel>
    <button class="carousel-control" data-carousel-prev aria-label="Show previous before and after image">‹</button>
    <div class="carousel-track" data-carousel-track>
      {items.map((item) => (
        <button class="carousel-slide" data-lightbox-src={item.src} data-lightbox-alt={item.alt}>
          <img src={item.src} alt={item.alt} loading="lazy" />
          <span>{item.title}</span>
        </button>
      ))}
    </div>
    <button class="carousel-control" data-carousel-next aria-label="Show next before and after image">›</button>
  </div>
</section>
